---
import { getCollection, render } from 'astro:content';
import StudiobauCard from './StudiobauCard.astro';
import { Image } from 'astro:assets';

const historieEntries = await getCollection('historie');
const sortedEntries = historieEntries.sort((a, b) => 
  new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);

// Alle einzigartigen Tags sammeln für die Filter-Buttons
const allTags = [...new Set(historieEntries.flatMap(entry => entry.data.tags))].sort();
---

<section class="py-16 px-4 bg-bonjwa-dark/30 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl font-bold text-white mb-4">Die Geschichte von Bonjwa</h2>
    <p class="text-gray-300 mb-16">Eine Dekade voller Meilensteine und Entwicklungen</p>
    
    <div class="mb-12 p-6 bg-black/20 rounded-3xl border border-white/5">
      <p class="text-xs uppercase tracking-widest text-bonjwa-accent mb-4 font-bold">Nach Kategorien filtern</p>
      <div class="flex flex-wrap gap-3">
        <button 
          class="filter-btn active bg-bonjwa-orange text-white px-4 py-2 rounded-xl text-sm transition-all shadow-orange-glow"
          data-tag="all"
        >
          Alle anzeigen
        </button>
        {allTags.map(tag => (
          <button 
            class="filter-btn bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white px-4 py-2 rounded-xl text-sm transition-all"
            data-tag={tag}
          >
            {tag}
          </button>
        ))}
      </div>
    </div>

    <div class="space-y-12" id="historie-list">
      {sortedEntries.map(async (entry) => {
        const { Content } = await render(entry);
        const tagString = entry.data.tags.join(' ');
        // Im Frontmatter deiner Astro-Komponente
        const { twitchClipId } = entry.data;

        // Eindeutige ID für den Container generieren
        const containerId = `twitch-container-${twitchClipId}`;

        const thumbnailUrl = `https://clips-media-assets2.twitch.tv/${twitchClipId}-preview-480x272.jpg`;
        const embedUrl = `https://clips.twitch.tv/embed?clip=${twitchClipId}&parent=projekt-medieninformatik.vercel.app&parent=localhost&autoplay=true&muted=false`;

        return (
          <div 
            class="historie-item bg-black/40 backdrop-blur-sm border border-white/10 p-6 rounded-3xl hover:border-bonjwa-orange/50 transition-all duration-500"
            data-tags={tagString}
          >
            <div class="flex items-start gap-4 mb-4">
                <div class="text-sm text-gray-400 mb-2">
                  {new Date(entry.data.date).toLocaleDateString('de-DE', {
                    year: 'numeric',
                    month: 'long',
                  })}
                </div>
            </div>
            
            <h3 class="text-2xl font-semibold text-white mb-3">
              {entry.data.title}
            </h3>
            
            <p class="text-gray-300 mb-4">
              {entry.data.description}
            </p>
            
            {entry.data.cover && (
              <div class="mb-6 rounded-lg overflow-hidden max-h-80">
                <Image 
                  src={entry.data.cover} 
                  alt={entry.data.title}
                  class="w-full h-full object-cover"
                />
              </div>
            )}
            
            <div class="prose prose-invert mb-6">
              <Content />
            </div>

            <StudiobauCard entry={entry} />

            {entry.data.twitchClipId && (
             <div id={containerId} 
                class="twitch-facade-container relative w-full aspect-video bg-black rounded-xl overflow-hidden cursor-pointer group border border-white/10 shadow-lg"
                data-embed-url={embedUrl}>
              
              <img 
                src={thumbnailUrl} 
                alt="Twitch Clip Vorschau" 
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />

              <div class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/20 transition-colors">
                <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center text-white text-3xl shadow-xl transition-transform group-hover:scale-110">
                  ▶
                </div>
              </div>
            </div>

            <script is:inline define:vars={{ containerId }}>
              // WICHTIG: Wir holen uns nur DIESEN EINEN Container
              const facade = document.getElementById(containerId);

              if (facade) {
                facade.addEventListener('click', function() {
                  const embedUrl = this.getAttribute('data-embed-url');
                  
                  const iframe = document.createElement('iframe');
                  iframe.setAttribute('src', embedUrl);
                  iframe.setAttribute('class', 'absolute inset-0 w-full h-full');
                  iframe.setAttribute('allowfullscreen', 'true');
                  iframe.setAttribute('allow', 'autoplay; fullscreen');
                  
                  this.innerHTML = '';
                  this.appendChild(iframe);
                  this.classList.remove('cursor-pointer');
                });
              }
            </script>
            )}
            
            {entry.data.youtubeVideoId && (
              <div class="mb-6 rounded-lg overflow-hidden bg-black">
                <iframe
                  width="100%"
                  height="400"
                  src={`https://www.youtube.com/embed/${entry.data.youtubeVideoId}`}
                  title={entry.data.title}
                  allowfullscreen
                  loading="lazy"
                >
                </iframe>
              </div>
            )}
            
            {entry.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {entry.data.tags.map((tag) => (
                  <span class="bg-gray-800 text-gray-300 text-xs px-3 py-1 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  import "../scripts/tagFilter.ts";
</script>
