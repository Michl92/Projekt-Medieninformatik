---
import { getCollection, render } from 'astro:content';
import StudiobauCard from './StudiobauCard.astro';
import { Image } from 'astro:assets';

const historieEntries = await getCollection('historie');
const sortedEntries = historieEntries.sort((a, b) => 
  new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);
---

<section class="py-16 px-4 bg-bonjwa-dark/30 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl font-bold text-white mb-4">Die Geschichte von Bonjwa</h2>
    <p class="text-gray-300 mb-16">Eine Dekade voller Meilensteine und Entwicklungen</p>
    
    <div class="space-y-12">
      {sortedEntries.map(async (entry) => {
        const { Content } = await render(entry);
        return (
          <div class="bg-black/40 backdrop-blur-sm border border-white/10 p-6 rounded-3xl hover:border-bonjwa-orange/50 transition-all duration-500">
            <div class="flex items-start gap-4 mb-4">
              <div>
                <div class="text-sm text-gray-400 mb-2">
                  {new Date(entry.data.date).toLocaleDateString('de-DE', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </div>
                {entry.data.milestone && (
                  <span class="inline-block bg-green-600 text-white text-xs px-2 py-1 rounded mb-2">
                    Meilenstein
                  </span>
                )}
              </div>
            </div>
            
            <h3 class="text-2xl font-semibold text-white mb-3">
              {entry.data.title}
            </h3>
            
            <p class="text-gray-300 mb-4">
              {entry.data.description}
            </p>
            
            {entry.data.cover && (
              <div class="mb-6 rounded-lg overflow-hidden max-h-80">
                <Image 
                  src={entry.data.cover} 
                  alt={entry.data.title}
                  class="w-full h-full object-cover"
                />
              </div>
            )}
            
            <div class="prose prose-invert mb-6">
              <Content />
            </div>

            <StudiobauCard entry={entry} />

            {entry.data.twitchClipId && (
              <div class="mb-6 rounded-lg overflow-hidden bg-black">
                <iframe
                  src={`https://clips.twitch.tv/embed?clip=${entry.data.twitchClipId}&parent=${Astro.url.hostname}`}
                  height="400"
                  width="100%"
                  allowfullscreen
                  loading="lazy"
                >
                </iframe>
              </div>
            )}
            
            {entry.data.youtubeVideoId && (
              <div class="mb-6 rounded-lg overflow-hidden bg-black">
                <iframe
                  width="100%"
                  height="400"
                  src={`https://www.youtube.com/embed/${entry.data.youtubeVideoId}`}
                  title={entry.data.title}
                  allowfullscreen
                  loading="lazy"
                >
                </iframe>
              </div>
            )}
            
            {entry.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {entry.data.tags.map((tag) => (
                  <span class="bg-gray-800 text-gray-300 text-xs px-3 py-1 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
