---
const { entry } = Astro.props;
if (!entry) throw new Error("Kein Historien-Eintrag übergeben.");// Im Frontmatter deiner Astro-Komponente

const { twitchClipId } = entry.data;

const embedUrlBase = `https://clips.twitch.tv/embed?clip=${twitchClipId}&autoplay=true&muted=false`;

// Eindeutige ID für den Container generieren
const containerId = `twitch-container-${twitchClipId}`;
---
{entry.data.twitchClipId && (
    <div id={containerId}  
    class="twitch-facade-container relative w-full aspect-video bg-black rounded-xl overflow-hidden cursor-pointer group border border-white/10 shadow-lg"
    data-embed-url={embedUrlBase}>

    <div class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/20 transition-colors">
    <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center text-white text-3xl shadow-xl transition-transform group-hover:scale-110">
        ▶
    </div>
    </div>
</div>

<script is:inline define:vars={{ containerId }}>
    const facade = document.getElementById(containerId);

    if (facade) {
    facade.addEventListener('click', function() {
        const embedUrlBase = this.getAttribute('data-embed-url');
        
        // Aktuelle Domain des Browsers 
        const currentHost = window.location.hostname;
        
        // Finale URL mit dynamischen Host als Parent
        const finalUrl = `${embedUrlBase}&parent=${currentHost}&parent=localhost`;
        
        const iframe = document.createElement('iframe');
        iframe.setAttribute('src', finalUrl);
        iframe.setAttribute('class', 'absolute inset-0 w-full h-full');
        iframe.setAttribute('allowfullscreen', 'true');
        iframe.setAttribute('allow', 'autoplay; fullscreen');
        
        this.innerHTML = '';
        this.appendChild(iframe);
        this.classList.remove('cursor-pointer');
    });
    }
</script>
)}