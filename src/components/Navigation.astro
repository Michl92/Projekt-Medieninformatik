---
---

<header
  class="sticky top-0 z-50 bg-bonjwa-dark/80 backdrop-blur-md border-b border-bonjwa-green/30 transition:persist"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="block">
          <div class="text-2xl font-display font-bold text-white hover:text-bonjwa-accent transition-colors duration-300 hover:shadow-[0_0_10px_rgba(43,233,148,0.5)]">
            Bonjwa
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-4">
          <a href="/historie" class="font-display text-white hover:text-bonjwa-orange transition-colors duration-300 relative group">
            Historie
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-bonjwa-orange shadow-[0_0_5px_rgba(255,138,0,0.8)] transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/live-stats" class="font-display text-white hover:text-bonjwa-orange transition-colors duration-300 relative group">
            Live-Stats
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-bonjwa-orange shadow-[0_0_5px_rgba(255,138,0,0.8)] transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/akademie" class="font-display text-white hover:text-bonjwa-orange transition-colors duration-300 relative group">
            Akademie
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-bonjwa-orange shadow-[0_0_5px_rgba(255,138,0,0.8)] transition-all duration-300 group-hover:w-full"></span>
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <details class="relative">
          <summary class="list-none cursor-pointer">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </summary>
          <div class="absolute right-0 mt-2 w-48 bg-bonjwa-dark/95 backdrop-blur-md rounded-md shadow-lg ring-1 ring-black ring-opacity-5">
            <div class="py-1">
              <a href="/historie" class="block px-4 py-2 font-display text-white hover:text-bonjwa-orange hover:bg-bonjwa-green/20 transition-colors duration-300">
                Historie
              </a>
              <a href="/live-stats" class="block px-4 py-2 font-display text-white hover:text-bonjwa-orange hover:bg-bonjwa-green/20 transition-colors duration-300">
                Live-Stats
              </a>
              <a href="/akademie" class="block px-4 py-2 font-display text-white hover:text-bonjwa-orange hover:bg-bonjwa-green/20 transition-colors duration-300">
                Akademie
              </a>
            </div>
          </div>
        </details>
      </div>
    </div>
  </nav>
</header>