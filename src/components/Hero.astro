---
import { getEntry, render } from 'astro:content';


const hero = await getEntry('sections', 'hero');
const { Content } = hero ? await render(hero) : { Content: () => null };
const title = hero?.data?.title ?? 'Bonjwa: Eine Dekade Gaming-Geschichte';
const backgroundImage = hero?.data?.backgroundImage?.src ?? '/assets/images/teamfoto/teamfoto.png';
---

<section

  style={`background-image: url('${backgroundImage}'); background-size: 100%; background-position: top; background-repeat: no-repeat;`}
>

  <div style='width:300px; height: 700px; margin:left;'>
    <h1 style='color: white; font-size: 2.5em; margin-top: 20px; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);'>
      {title}
    </h1>
    <div  style='color: white; border-radius: 10px; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);'>
      <Content />
    </div>
  </div>
</section>
